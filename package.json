{
  "name": "motoflow-pro",
  "private": true,
  "version": "1.0.0",
  "description": "MotoFlow Pro - Gestión de Taller de Motos",
  "author": "MotoFlow",
  "type": "commonjs",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "reset-admin": "node -e \"process.env.MOTOFLOW_RESET_ADMIN='1';require('child_process').spawnSync(process.platform==='win32'?'npx.cmd':'npx',['electron','.'],{stdio:'inherit',env:process.env})\"",
    "build:exe": "electron-builder --dir"
  },
  "engines": {
    "node": ">=18.18"
  },
  "overrides": {
    "protobufjs": "^7.5.5",
    "uuid": "^14.0.0",
    "file-type": "^22.0.1",
    "music-metadata": "^11.12.3"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.17.16",
    "axios": "^1.15.2",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.4",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "sql.js": "^1.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.21",
    "electron": "^40.9.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "lovable-tagger": "^1.1.13",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  },
  "build": {
    "asar": false,
    "appId": "com.motoflow.desktop",
    "productName": "MotoFlow Pro",
    "icon": "public/favicon.ico",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**",
      "electron/**",
      "backend/**",
      "server/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/uploads",
        "to": "uploads"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/favicon.ico"
    }
  }
}
